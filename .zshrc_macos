# Enable Powerlevel10k instant prompt. Must stay at the top of ~/.zshrc.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# --- Oh My Zsh ---
export ZSH="$HOME/.oh-my-zsh"

plugins=(
  git
  zsh-autosuggestions
  zsh-syntax-highlighting
  colored-man-pages
  docker
  docker-compose
  aws
  terraform
  kubectl
  aliases
  ansible
  brew
  autoenv
  opentofu
  gh
)

source $ZSH/oh-my-zsh.sh

# --- History ---
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE

# --- Powerlevel10k ---
source ~/powerlevel10k/powerlevel10k.zsh-theme
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# --- Exports ---
export GPG_TTY=$(tty)
export GOBIN=$HOME/go/bin

export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# --- PATH ---
export PATH=${PATH}:$(go env GOPATH)/bin

# --- Evals ---
eval "$(pyenv init -)"
eval "$(zoxide init zsh)"
source <(fzf --zsh)

# --- Aliases ---
alias vim="nvim"
alias cat="bat --pager=never"
alias lz="lazygit"
alias lzd="lazydocker"
alias aur="auth-refresher"
alias ktx="kontext"
alias redis-cli="docker run --network host --rm -it redis:alpine redis-cli"

# Kubernetes
alias k=kubecolor
compdef kubecolor=kubectl
setNS() { kubectl config set-context --current --namespace="$@" ; }

# --- Completions ---
source <(aws-cli-manager completion zsh)
source <(kontext completion zsh)
source <(gclone completion zsh)
source <(helm completion zsh)
source <(tenv completion zsh)
eval "$(task --completion zsh)"

. "$HOME/.local/bin/env"
